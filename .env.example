# ==============================================================================
# .env.example: Environment Configuration Spec Template
# Copy this file to '.env' and modify settings for local/production runs.
# ==============================================================================

# ------------------------------------------------------------------------------
# Ingestion Buffer (Apache Kafka) Configuration
# ------------------------------------------------------------------------------
# Internal listener port exposed inside the bridge network
KAFKA_PORT=9092

# External listener port exposed to the host machine
KAFKA_HOST_PORT=29092

# Unique identifier for the Kafka KRaft cluster
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# ------------------------------------------------------------------------------
# Serving Layer (Redis) Configuration
# ------------------------------------------------------------------------------
# Port exposed by the Redis caching engine on the host
REDIS_PORT=6379

# Secure password required for Redis connection authentication (Mandatory)
REDIS_PASSWORD=aSecureRedisPassword123

# ------------------------------------------------------------------------------
# Streaming Core Engine (Apache Flink) Configuration
# ------------------------------------------------------------------------------
# Hostname or container ID of the Flink master node
FLINK_JOBMANAGER_RPC_ADDRESS=flink-jobmanager

# Port exposed on the host machine to access Flink's web dashboard UI
FLINK_JOBMANAGER_PORT=8082

# Total memory allocated to the JobManager process (heap + off-heap)
FLINK_JOBMANAGER_MEM_SIZE=1024m

# Total memory allocated to the TaskManager process (heap + off-heap)
FLINK_TASKMANAGER_MEM_SIZE=2048m

# Off-heap Flink framework memory allocation size
FLINK_TASKMANAGER_HEAP_FRAMEWORK=128m

# Heap memory allocated specifically to user processing tasks
FLINK_TASKMANAGER_HEAP_TASK=512m

# Managed memory allocated for sorting, state caching, and intermediate buffers
FLINK_TASKMANAGER_MANAGED=256m

# Number of parallel task slots available on the Flink TaskManager worker
FLINK_TASK_SLOTS=4

# ------------------------------------------------------------------------------
# Telemetry Data Generator Configuration
# ------------------------------------------------------------------------------
# Target emission frequency in events per second (throttling boundary)
TELEMETRY_GENERATOR_RATE=15

# Total number of unique simulated transport trucks in the fleet
TELEMETRY_GENERATOR_VEHICLES=8

# Percentage of events artificially delayed to simulate network drops (0.0 to 1.0)
TELEMETRY_GENERATOR_LATE_PCT=0.10

# Maximum simulated latency offset in seconds for out-of-order data
TELEMETRY_GENERATOR_MAX_DELAY_SEC=12

# ------------------------------------------------------------------------------
# PII & Data Pseudonymization Configuration
# ------------------------------------------------------------------------------
# Set to 'true' to enable SHA-256 pseudonymization of vehicle_id before writing to Redis
PSEUDONYMIZE_PII=false

# Secure salt used during the hashing transformation to prevent dictionary attacks
PII_SALT=default_secure_salt_value

# ------------------------------------------------------------------------------
# S3 / MinIO Object Storage Emulator Configuration
# ------------------------------------------------------------------------------
# Access key ID (username) for MinIO
AWS_ACCESS_KEY_ID=minioadmin

# Secret access key (password) for MinIO
AWS_SECRET_ACCESS_KEY=minioadminpassword

# Target S3 endpoint URL (MinIO internally)
S3_ENDPOINT=http://minio:9000

# Host mapped ports for MinIO API and Console dashboard
MINIO_PORT_HOST=9000
MINIO_CONSOLE_PORT_HOST=9001

# The target bucket name for Dead-Letter Queue (DLQ) records
DLQ_S3_BUCKET=fleet-telemetry-dlq

